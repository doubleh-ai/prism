# Prism — 环境变量模板
# 复制为 .env 并填入实际值（.env 已加入 .gitignore，不会泄露）
#
# 获取 API Key:
#   DeepSeek   → https://platform.deepseek.com/api_keys
#   MiniMax    → https://platform.minimax.io/subscribe/token-plan

# ── 模型 API Keys（按平台独立配置）──
DEEPSEEK_API_KEY=sk-your-deepseek-key
MINIMAX_API_KEY=sk-your-minimax-key

# 兼容旧版: 如果上面两个没设置，fallback 到此变量
# LLM_API_KEY=sk-legacy-key

# ── 可选覆盖 ──
# STOCK_DATA_DIR=/home/ubuntu/stock-data
# CLAUDE_BIN=/home/ubuntu/.npm-global/bin/claude
# CLAUDE_SKILLS_HOME=/home/ubuntu/.claude/skills
# RATE_CHAT_PER_MIN=20
# RATE_LOGIN_PER_MIN=10
# STOCK_LOG_FILE=/var/log/stock-app.log
